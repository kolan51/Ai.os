# Ai.os — environment variables
# Copy this file to .env and fill in your keys

# ── LLM Providers ────────────────────────────────────────────────────────────
# At least one is required depending on the model your agents use

ANTHROPIC_API_KEY=         # claude-* models — https://console.anthropic.com
OPENAI_API_KEY=             # gpt-* models    — https://platform.openai.com/api-keys
GOOGLE_API_KEY=             # gemini-* models  — https://aistudio.google.com/app/apikey
MISTRAL_API_KEY=            # mistral-* models — https://console.mistral.ai

# ── Local Models (Ollama) ─────────────────────────────────────────────────────
# No key needed — just have Ollama running: https://ollama.com
# Model string: "ollama/llama3", "ollama/mistral", etc.

# ── Optional ─────────────────────────────────────────────────────────────────
AIOS_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
AIOS_DATA_DIR=              # Override default ~/.aios/data
